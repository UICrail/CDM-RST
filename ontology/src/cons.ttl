@prefix : <http://cdm.ovh/rst/cons/cons#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dul: <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix cons: <https://cdm.ovh/rst/cons/cons#> .
@prefix list: <https://cdm.ovh/rsm/list2/list2#> .
@prefix loca: <https://cdm.ovh/rsm/localisation/loca#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <https://vocab.org/vann/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@base <http://cdm.ovh/rst/cons/cons> .

<http://cdm.ovh/rst/cons/cons> rdf:type owl:Ontology ;
                                owl:versionIRI <http://cdm.ovh/rst/cons/0.3/cons> ;
                                owl:imports <https://cdm.ovh/rsm/list2/list2> ;
                                dc:creator "Airy Magnien, UIC" ;
                                dc:date "20 April 2026" ;
                                dcterms:description "Defines rolling stock (vehicles, formations), their partship relations, and their coupling relations."@en ;
                                dcterms:license <http://purl.org/dc/elements/1.1/https://creativecommons.org/licenses/by-sa/4.0/> ;
                                dcterms:title "Rolling stock consist ontology"@en ;
                                owl:versionInfo "0.2: added some DUL alignment. Using the 'side' SKOS concept scheme."@en ,
                                                "0.3: Imports modified List ontology"@en ;
                                vann:preferredNamespacePrefix "cons" ;
                                vann:preferredNamespaceURI <https://cdm.ovh/rst/cons/cons> .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/elements/1.1/creator
dc:creator rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/date
dc:date rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
dcterms:description rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
dcterms:license rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
dcterms:title rdf:type owl:AnnotationProperty .


###  https://vocab.org/vann/preferredNamespacePrefix
vann:preferredNamespacePrefix rdf:type owl:AnnotationProperty .


###  https://vocab.org/vann/preferredNamespaceURI
vann:preferredNamespaceURI rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#decimal
xsd:decimal rdf:type rdfs:Datatype .


###  http://www.w3.org/2001/XMLSchema#integer
xsd:integer rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  https://cdm.ovh/rsm/list2/list2#hasNext
list:hasNext rdf:type owl:ObjectProperty .


###  https://cdm.ovh/rst/cons/cons#coupledTo
cons:coupledTo rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf cons:facesExtremity ;
               rdf:type owl:FunctionalProperty ,
                        owl:InverseFunctionalProperty ,
                        owl:SymmetricProperty ,
                        owl:IrreflexiveProperty ;
               rdfs:comment "Symmetric property \"coupled to\" relates two extremities of two distinct Rolling stock items (hence the \"to\" in the label). The property is expressed irrespectively of the type of coupling (mechanical, virtual) or coupler (UIC, Scharfenberg...)."@en ;
               rdfs:label "coupled to" .


###  https://cdm.ovh/rst/cons/cons#extremity_1
cons:extremity_1 rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf cons:hasExtremity ;
                 rdf:type owl:FunctionalProperty ,
                          owl:InverseFunctionalProperty ;
                 owl:propertyDisjointWith cons:extremity_2 ;
                 rdfs:comment "\"extremity 1\" (actual designation may vary) of a Rolling stock. This extremity is inherent to the rolling stock, this unrelated to the direction of travel."@en ;
                 rdfs:label "extremity_1"@en .


###  https://cdm.ovh/rst/cons/cons#extremity_2
cons:extremity_2 rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf cons:hasExtremity ;
                 rdf:type owl:FunctionalProperty ,
                          owl:InverseFunctionalProperty ;
                 rdfs:comment "\"extremity 2\" of a piece of Rolling stock. Designation may vary."@en ;
                 rdfs:label "extremity_2"@en .


###  https://cdm.ovh/rst/cons/cons#facesExtremity
cons:facesExtremity rdf:type owl:ObjectProperty ,
                             owl:FunctionalProperty ,
                             owl:InverseFunctionalProperty ,
                             owl:SymmetricProperty ,
                             owl:IrreflexiveProperty ;
                    rdfs:domain cons:Extremity ;
                    rdfs:range cons:Extremity ;
                    rdfs:comment "object is the extremity of another Rolling stock that the subject extremity faces."@en ;
                    rdfs:label "faces extremity"@en .


###  https://cdm.ovh/rst/cons/cons#frontExtremity
cons:frontExtremity rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf cons:hasExtremity ;
                    rdf:type owl:FunctionalProperty ,
                             owl:InverseFunctionalProperty ;
                    rdfs:domain cons:ListedRollingStock ;
                    rdfs:range cons:Extremity ;
                    rdfs:comment "The extremity first encountered when considering the formation in the listed order. This property orients the vehicle in the formation that itself is oriented. Note: when considering a passing-by train, the first encountered vehicles and vehicle extremities depend on running direction that is NOT considered here at all. The preeent ontology only describes rolling stock."@en ;
                    rdfs:label "front extremity"@en .


###  https://cdm.ovh/rst/cons/cons#hasExtremity
cons:hasExtremity rdf:type owl:ObjectProperty ,
                           owl:InverseFunctionalProperty ;
                  rdfs:domain cons:RollingStock ;
                  rdfs:range cons:Extremity ;
                  rdfs:label "has extremity"@en .


###  https://cdm.ovh/rst/cons/cons#hasHeadRollingStock
cons:hasHeadRollingStock rdf:type owl:ObjectProperty ;
                         rdfs:subPropertyOf cons:includesRollingStock ;
                         rdf:type owl:FunctionalProperty ,
                                  owl:InverseFunctionalProperty ;
                         rdfs:domain cons:Formation ;
                         rdfs:range cons:ListedRollingStock ;
                         rdfs:comment "Each formation has exactly one \"First\" rolling stock. This notion of \"first\" is only related to the rolling stock, not however to the direction of travel which may vary (general case of multiple units or reversible trains) or not (case of hauled freight trains). Please also not that the direction of movement is yet another notion (think of shunting)."@en ;
                         rdfs:label "has head rolling stock"@en .


###  https://cdm.ovh/rst/cons/cons#hasNextRollingStock
cons:hasNextRollingStock rdf:type owl:ObjectProperty ;
                         rdfs:subPropertyOf list:hasNext ;
                         rdf:type owl:FunctionalProperty ,
                                  owl:InverseFunctionalProperty ;
                         rdfs:domain cons:ListedRollingStock ;
                         rdfs:range [ rdf:type owl:Class ;
                                      owl:unionOf ( list:EmptyList
                                                    cons:ListedRollingStock
                                                  )
                                    ] ;
                         rdfs:comment "Indicates which Rolling stock comes next in a Consist. The ' next rolling stock' can be a vehicle, a formation, or an instance of EmptyList (for which the list:emptyList individual is the recommended form)."@en ;
                         rdfs:label "has next rolling stock"@en .


###  https://cdm.ovh/rst/cons/cons#hasSide
cons:hasSide rdf:type owl:ObjectProperty ,
                      owl:InverseFunctionalProperty ;
             rdfs:domain cons:RollingStock ;
             rdfs:range cons:RollingStockSide ;
             rdfs:label "has side"@en .


###  https://cdm.ovh/rst/cons/cons#includesRollingStock
cons:includesRollingStock rdf:type owl:ObjectProperty ;
                          owl:inverseOf cons:partOfFormation ;
                          rdf:type owl:InverseFunctionalProperty ,
                                   owl:IrreflexiveProperty ;
                          rdfs:domain cons:Formation ;
                          rdfs:range cons:RollingStock ;
                          rdfs:comment "This property describes the composition of a Formation. A Formation may incude any rolling stock (i.e. vehicles or formations). Irreflexive property: a formation cannot include itself; in other words, it may only have proper parts. This property and its inverse are ancillary properties, to be derived from the nested, listed rolling stock. Consistency of consist representations is the responsibility of the user."@en ;
                          rdfs:label "includes Rolling stock"@en .


###  https://cdm.ovh/rst/cons/cons#isExtremityOf
cons:isExtremityOf rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf [ owl:inverseOf cons:hasExtremity
                                      ] ;
                   rdf:type owl:FunctionalProperty ;
                   rdfs:label "is extremity of"@en .


###  https://cdm.ovh/rst/cons/cons#isSide
cons:isSide rdf:type owl:ObjectProperty ;
            rdfs:domain cons:RollingStockSide ;
            rdfs:range skos:Concept ;
            rdfs:comment "property objects can be found under the scheme https://cdm.ovh/rsm/schemes/side. Not a functional property, as e.g. \"left\" can be combined with either \"exterior\" or \" interior\" (orientation + polarity)"@en ;
            rdfs:label "is side"@en .


###  https://cdm.ovh/rst/cons/cons#isSideOf
cons:isSideOf rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf [ owl:inverseOf cons:hasSide
                                 ] ;
              rdf:type owl:FunctionalProperty ;
              rdfs:label "is side of" .


###  https://cdm.ovh/rst/cons/cons#partOfFormation
cons:partOfFormation rdf:type owl:ObjectProperty ,
                              owl:FunctionalProperty ,
                              owl:IrreflexiveProperty ;
                     rdfs:comment "Inverse of \"includes Rolling Stock\". A functional property: a rolling stock can only be part of one formation. Irreflexive property: A formation cannot be part of itself."@en ;
                     rdfs:label "part of formation"@en .


###  https://cdm.ovh/rst/cons/cons#rstLocation
cons:rstLocation rdf:type owl:ObjectProperty ,
                          owl:InverseFunctionalProperty ;
                 rdfs:domain cons:LocatedRollingStockElement ;
                 rdfs:range loca:BaseLocation ;
                 rdfs:comment "The rolling stock location can be represented as a linear location (e.g. position along a track) or a spot location (e.g. location of the front axle on the track centerline) according to needs or conventions. These may give rise to several subclasses with definite semantics. In less typical cases (e.g. workshop floorplan), an area location can be used."@en ;
                 rdfs:label "rolling stock location"@en .


#################################################################
#    Data properties
#################################################################

###  https://cdm.ovh/rst/cons/cons#hasMetricLength
cons:hasMetricLength rdf:type owl:DatatypeProperty ;
                     rdfs:domain cons:RollingStock ;
                     rdfs:range xsd:decimal ;
                     rdfs:label "has metric length"@en .


###  https://cdm.ovh/rst/cons/cons#lengthOverBuffers
cons:lengthOverBuffers rdf:type owl:DatatypeProperty ;
                       rdfs:subPropertyOf cons:hasMetricLength ;
                       rdfs:label "length over buffers"@en .


###  https://cdm.ovh/rst/cons/cons#lengthOverCouplers
cons:lengthOverCouplers rdf:type owl:DatatypeProperty ;
                        rdfs:subPropertyOf cons:hasMetricLength ;
                        rdfs:label "length over couplers"@en .


###  https://cdm.ovh/rst/cons/cons#positionInFormation
cons:positionInFormation rdf:type owl:DatatypeProperty ,
                                  owl:FunctionalProperty ;
                         rdfs:domain cons:RollingStock ;
                         rdfs:range xsd:integer ;
                         rdfs:comment "Starting with 1. Ancillary property, the value of which shall be derived from the nested rolling stock list"@en ;
                         rdfs:label "position in formation"@en .


#################################################################
#    Classes
#################################################################

###  http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#DesignedArtifact
dul:DesignedArtifact rdf:type owl:Class .


###  http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#PhysicalArtifact
dul:PhysicalArtifact rdf:type owl:Class .


###  http://www.w3.org/2004/02/skos/core#Concept
skos:Concept rdf:type owl:Class ;
             rdfs:label "Concept"@en .


###  https://cdm.ovh/rsm/list2/list2#EmptyList
list:EmptyList rdf:type owl:Class ;
               owl:disjointWith cons:ListedRollingStock .


###  https://cdm.ovh/rsm/list2/list2#OWLList
list:OWLList rdf:type owl:Class .


###  https://cdm.ovh/rsm/localisation/loca#BaseLocation
loca:BaseLocation rdf:type owl:Class .


###  https://cdm.ovh/rst/cons/cons#Extremity
cons:Extremity rdf:type owl:Class ;
               rdfs:subClassOf cons:LocatedRollingStockElement ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty [ owl:inverseOf cons:hasExtremity
                                                ] ;
                                 owl:someValuesFrom owl:Thing
                               ] ;
               rdfs:comment "denotes the extremity of a rolling stock. The extremity designation is either set at design and manufacturing time (e.g. extremity1, extremity 2 in the case of a wagon), or rests on other conventions (e.g. extremities of a variable-consist trainset)."@en ;
               rdfs:label "Extremity"@en .


###  https://cdm.ovh/rst/cons/cons#Formation
cons:Formation rdf:type owl:Class ;
               rdfs:subClassOf cons:RollingStock ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty cons:includesRollingStock ;
                                 owl:someValuesFrom owl:Thing
                               ] ;
               owl:disjointWith cons:Vehicle ;
               rdfs:comment "A sequence of vehicles (or other formations) that are coupled in some way (mechanically or virtually)."@en ;
               rdfs:label "Formation"@en .


###  https://cdm.ovh/rst/cons/cons#ListedRollingStock
cons:ListedRollingStock rdf:type owl:Class ;
                        rdfs:subClassOf list:OWLList ,
                                        cons:RollingStock ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty cons:hasNextRollingStock ;
                                          owl:someValuesFrom owl:Thing
                                        ] ;
                        rdfs:comment "Rolling stock that may have a predecessor or successor in a formation."@en ;
                        rdfs:label "Listed rolling stock"@en .


###  https://cdm.ovh/rst/cons/cons#LocatedRollingStockElement
cons:LocatedRollingStockElement rdf:type owl:Class ;
                                rdfs:label "Located rolling stock element"@en .


###  https://cdm.ovh/rst/cons/cons#RollingStock
cons:RollingStock rdf:type owl:Class ;
                  rdfs:subClassOf dul:PhysicalArtifact ,
                                  cons:LocatedRollingStockElement ;
                  rdfs:comment "Base type for rolling stock. No direct instances are expected."@en ;
                  rdfs:label "Rolling stock"@en .


###  https://cdm.ovh/rst/cons/cons#RollingStockSide
cons:RollingStockSide rdf:type owl:Class ;
                      rdfs:subClassOf [ rdf:type owl:Restriction ;
                                        owl:onProperty cons:isSide ;
                                        owl:someValuesFrom owl:Thing
                                      ] ;
                      rdfs:comment "The side of a particular rolling stock, as in \"the left side of locomotive BB15046\"."@en ;
                      rdfs:label "Rolling stock side"@en .


###  https://cdm.ovh/rst/cons/cons#Vehicle
cons:Vehicle rdf:type owl:Class ;
             rdfs:subClassOf dul:DesignedArtifact ,
                             cons:RollingStock ;
             rdfs:comment """Common definition in Directives 2016/797, 2016/798:
 a railway vehicle suitable for circulation on wheels on railway lines, with or without traction; a vehicle is composed of one or more structural and functional subsystems

ERA vocabulary 3.0.0: A specific vehicle or wagon able to operate over railway lines."""@en ,
                          "Considered to be the atomic part of a piece of rolling stock, although disassembly may be carried out in special circumstances. Example: a TALGO or TGV trailer does not rest on two axles resp. bogies, but has a distinct carbody and it considered a vehicle (called \"trailer\").  Further example: an articulated wagon (3-axle, e.g. carrying cars) is generally considered a single vehicle although it has two distinct chassis. So the distinction vehicle / formation is conventional; being \"atomic\" in operations is a necessary condition, but not a sufficient one to be called vehicle."@en ;
             rdfs:label "Vehicle"@en .



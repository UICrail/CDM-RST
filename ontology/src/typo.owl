<?xml version="1.0"?>
<rdf:RDF xmlns="http://cdm.ovh/rst/typo/typo#"
     xml:base="http://cdm.ovh/rst/typo/typo"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:dcterms="http://purl.org/dc/terms/"
     xmlns:rst-cons="https://cdm.ovh/rst/cons/cons#"
     xmlns:rst-typo="https://cdm.ovh/rst/typo/typo#">
    <owl:Ontology rdf:about="http://cdm.ovh/rst/typo/typo">
        <owl:versionIRI rdf:resource="http://cdm.ovh/rst/typo/0.3/typo"/>
        <dc:author>Airy Magnien, UIC</dc:author>
        <dc:date>5 May 2026</dc:date>
        <dcterms:description xml:lang="en">Defines:
* terms such as locomotive, wagon, trailer...
* features such as motored, passenger-carrying, freight-carrying...
* relations with rolling stock composition (vehicle, formation) that is the subject of another ontology.</dcterms:description>
        <dcterms:license rdf:resource="https://creativecommons.org/licenses/by-sa/4.0/"/>
        <dcterms:title xml:lang="en">Railway rolling stock typology</dcterms:title>
        <vann:preferredNamespacePrefix>typo</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceURI>https://cdm.ovh/rst/typo/typo</vann:preferredNamespaceURI>
        <rdfs:comment xml:lang="en">This ontology was created in the context of the collaboration with the ERJU System Pillar works. The consequence is the preference given to a class hierachy for rolling stock types that is closer to anticipated downstream works (SysML modelling), compared to enumerated types that is another solution often encountered.</rdfs:comment>
        <owl:versionInfo xml:lang="en">0.3 Edited license, removed useless prefix</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.org/dc/elements/1.1/author -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/author"/>
    


    <!-- http://purl.org/dc/elements/1.1/date -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/date"/>
    


    <!-- http://purl.org/dc/terms/description -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/description"/>
    


    <!-- http://purl.org/dc/terms/license -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>
    


    <!-- http://purl.org/dc/terms/title -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/title"/>
    


    <!-- http://purl.org/vocab/vann/preferredNamespacePrefix -->

    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespacePrefix"/>
    


    <!-- http://purl.org/vocab/vann/preferredNamespaceURI -->

    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespaceURI"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.w3.org/2001/XMLSchema#boolean -->

    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#boolean"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://cdm.ovh/rsm/rolling_stock/rolling_stock_typology#hasFixedConsist -->

    <owl:DatatypeProperty rdf:about="http://cdm.ovh/rsm/rolling_stock/rolling_stock_typology#hasFixedConsist">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rst/cons/cons#Formation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Train formation, the consist of which cannot be changed while in operations as it would require interventions in a workshop.</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://cdm.ovh/rst/cons/cons#Formation -->

    <owl:Class rdf:about="https://cdm.ovh/rst/cons/cons#Formation"/>
    


    <!-- https://cdm.ovh/rst/cons/cons#Vehicle -->

    <owl:Class rdf:about="https://cdm.ovh/rst/cons/cons#Vehicle">
        <rdfs:comment xml:lang="en">Common definition in Directives 2016/797, 2016/798:
 a railway vehicle suitable for circulation on wheels on railway lines, with or without traction; a vehicle is composed of one or more structural and functional subsystems

ERA vocabulary 3.0.0: A specific vehicle or wagon able to operate over railway lines.</rdfs:comment>
    </owl:Class>
    


    <!-- https://cdm.ovh/rst/typo/typo#Coach -->

    <owl:Class rdf:about="https://cdm.ovh/rst/typo/typo#Coach">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rst/cons/cons#Vehicle"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rst/typo/typo#PassengerCarryingRollingStock"/>
        <rdfs:comment xml:lang="en">TSI LOCPAS 2020:
a vehicle without traction in a fixed or variable formation capable of carrying passengers (by extension, requirements specified to apply to coaches in this TSI are deemed to apply also to restaurant cars, sleeping cars, couchettes cars, etc.)

Note: was &quot;passenger carriage&quot; in earlier versions.</rdfs:comment>
    </owl:Class>
    


    <!-- https://cdm.ovh/rst/typo/typo#FreightCarryingRollingStock -->

    <owl:Class rdf:about="https://cdm.ovh/rst/typo/typo#FreightCarryingRollingStock">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rst/typo/typo#RollingStockFeature"/>
        <rdfs:comment xml:lang="en">Feature of Rolling stock: ability to carry freight, by design.</rdfs:comment>
    </owl:Class>
    


    <!-- https://cdm.ovh/rst/typo/typo#Locomotive -->

    <owl:Class rdf:about="https://cdm.ovh/rst/typo/typo#Locomotive">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rst/cons/cons#Vehicle"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rst/typo/typo#MotoredRollingStock"/>
        <rdfs:comment xml:lang="en">Powered vehicle having a driving desk and can be used standalone (e.g. for shunting or ferrying movements), but is normally used for hauling other vehicles or formations.</rdfs:comment>
        <rdfs:label xml:lang="en">Locomotive</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rst/typo/typo#MotorCar -->

    <owl:Class rdf:about="https://cdm.ovh/rst/typo/typo#MotorCar">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rst/cons/cons#Vehicle"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rst/typo/typo#MotoredRollingStock"/>
        <rdfs:comment xml:lang="en">Powered vehicle that cannot be used standalone, as can be found in trainset (EMUs or DMUs).
May or may not carry passengers.</rdfs:comment>
    </owl:Class>
    


    <!-- https://cdm.ovh/rst/typo/typo#MotoredRollingStock -->

    <owl:Class rdf:about="https://cdm.ovh/rst/typo/typo#MotoredRollingStock">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rst/typo/typo#RollingStockFeature"/>
        <rdfs:comment xml:lang="en">Feature of rolling stock that is able by design to exert tractive effort on wheels or (rarely) cogwheels.</rdfs:comment>
    </owl:Class>
    


    <!-- https://cdm.ovh/rst/typo/typo#OnTrackMachine -->

    <owl:Class rdf:about="https://cdm.ovh/rst/typo/typo#OnTrackMachine">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rst/cons/cons#Vehicle"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rst/typo/typo#MotoredRollingStock"/>
        <rdfs:comment xml:lang="en">a motored railway vehicle used for infrastructure maintenance</rdfs:comment>
    </owl:Class>
    


    <!-- https://cdm.ovh/rst/typo/typo#PassengerCarryingRollingStock -->

    <owl:Class rdf:about="https://cdm.ovh/rst/typo/typo#PassengerCarryingRollingStock">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rst/typo/typo#RollingStockFeature"/>
        <rdfs:comment xml:lang="en">Feature of Rolling stock: ability to carry freight, by design.</rdfs:comment>
    </owl:Class>
    


    <!-- https://cdm.ovh/rst/typo/typo#RailCar -->

    <owl:Class rdf:about="https://cdm.ovh/rst/typo/typo#RailCar">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rst/cons/cons#Vehicle"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rst/typo/typo#MotoredRollingStock"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rst/typo/typo#PassengerCarryingRollingStock"/>
        <rdfs:comment xml:lang="en">Wikipedia (12/3/2024): self-propelled railway vehicle designed to transport passengers.
Equiv. to FR: Autorail, DE: Schienenbus (narrower meaning: two axles only).
Note however the numerous variants and ambiguities.</rdfs:comment>
    </owl:Class>
    


    <!-- https://cdm.ovh/rst/typo/typo#Rake -->

    <owl:Class rdf:about="https://cdm.ovh/rst/typo/typo#Rake">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rst/cons/cons#Formation"/>
        <rdfs:comment xml:lang="en">Any non-powered formation. Examples:
wagon rake;
(fixed consist) set of TGV trailers;
(fixed or variable consist) rake of coaches.</rdfs:comment>
    </owl:Class>
    


    <!-- https://cdm.ovh/rst/typo/typo#RoadRailVehicle -->

    <owl:Class rdf:about="https://cdm.ovh/rst/typo/typo#RoadRailVehicle">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rst/cons/cons#Vehicle"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rst/typo/typo#FreightCarryingRollingStock"/>
    </owl:Class>
    


    <!-- https://cdm.ovh/rst/typo/typo#RoadVehicleRake -->

    <owl:Class rdf:about="https://cdm.ovh/rst/typo/typo#RoadVehicleRake">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rst/cons/cons#Formation"/>
        <rdfs:comment xml:lang="en">From TSI WAG 2023, &quot;unit&quot;, 3rd entry:
separate rail bogies connected to compatible road vehicle(s), the combination of which forms a rake of a rail compatible system.</rdfs:comment>
    </owl:Class>
    


    <!-- https://cdm.ovh/rst/typo/typo#RollingStockFeature -->

    <owl:Class rdf:about="https://cdm.ovh/rst/typo/typo#RollingStockFeature"/>
    


    <!-- https://cdm.ovh/rst/typo/typo#SlaveLocomotive -->

    <owl:Class rdf:about="https://cdm.ovh/rst/typo/typo#SlaveLocomotive">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rst/cons/cons#Vehicle"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rst/typo/typo#MotoredRollingStock"/>
        <rdfs:comment xml:lang="en">Powered vehicle without driving desk, with energy possibly fed from master locomotive ( = subclass &quot;slug&quot;).
Also called &quot;truck&quot; in France, e.g. TC61000.
Do not confuse with master/slave configuration of two normal locomotives (&quot;multiple working&quot; in the UK).</rdfs:comment>
    </owl:Class>
    


    <!-- https://cdm.ovh/rst/typo/typo#Trailer -->

    <owl:Class rdf:about="https://cdm.ovh/rst/typo/typo#Trailer">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rst/cons/cons#Vehicle"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rst/typo/typo#PassengerCarryingRollingStock"/>
        <rdfs:comment xml:lang="en">non-traction, passenger-carrying vehicle that is part of a trainset or of a fixed-consist rake, such as TGV trailer or ICE3 trailer or Talgo trailer.</rdfs:comment>
    </owl:Class>
    


    <!-- https://cdm.ovh/rst/typo/typo#Trainset -->

    <owl:Class rdf:about="https://cdm.ovh/rst/typo/typo#Trainset">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rst/cons/cons#Formation"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rst/typo/typo#MotoredRollingStock"/>
        <rdfs:comment xml:lang="en">TSI LOC&amp;PAS, 2020: a fixed formation that can operate as a train; it is by definition not intended to be reconfigured, except within a workshop environment. It is composed of only motored or of motored and non-motored vehicles.</rdfs:comment>
    </owl:Class>
    


    <!-- https://cdm.ovh/rst/typo/typo#Van -->

    <owl:Class rdf:about="https://cdm.ovh/rst/typo/typo#Van">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rst/cons/cons#Vehicle"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rst/typo/typo#FreightCarryingRollingStock"/>
        <rdfs:comment xml:lang="en">TSI LOCPAS 2020: a vehicle without traction capable of carrying payload other than passengers, e.g. luggage or mail, intended to be integrated into a fixed or variable formation which is intended to transport passengers.</rdfs:comment>
    </owl:Class>
    


    <!-- https://cdm.ovh/rst/typo/typo#Wagon -->

    <owl:Class rdf:about="https://cdm.ovh/rst/typo/typo#Wagon">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rst/cons/cons#Vehicle"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rst/typo/typo#FreightCarryingRollingStock"/>
        <rdfs:comment xml:lang="en">A non-powered vehicle designed for carrying freight.</rdfs:comment>
        <rdfs:label xml:lang="en">Wagon</rdfs:label>
    </owl:Class>
</rdf:RDF>




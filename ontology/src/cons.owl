<?xml version="1.0"?>
<rdf:RDF xmlns="http://cdm.ovh/rst/cons/cons#"
     xml:base="http://cdm.ovh/rst/cons/cons"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:dul="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:cons="https://cdm.ovh/rst/cons/cons#"
     xmlns:list="https://cdm.ovh/rsm/list2/list2#"
     xmlns:loca="https://cdm.ovh/rsm/localisation/loca#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:vann="https://vocab.org/vann/"
     xmlns:dcterms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="http://cdm.ovh/rst/cons/cons">
        <owl:versionIRI rdf:resource="http://cdm.ovh/rst/cons/0.3/cons"/>
        <owl:imports rdf:resource="https://cdm.ovh/rsm/list2/list2"/>
        <dc:creator>Airy Magnien, UIC</dc:creator>
        <dc:date>20 April 2026</dc:date>
        <dcterms:description xml:lang="en">Defines rolling stock (vehicles, formations), their partship relations, and their coupling relations.</dcterms:description>
        <dcterms:license rdf:resource="http://purl.org/dc/elements/1.1/https://creativecommons.org/licenses/by-sa/4.0/"/>
        <dcterms:title xml:lang="en">Rolling stock consist ontology</dcterms:title>
        <owl:versionInfo xml:lang="en">0.2: added some DUL alignment. Using the &apos;side&apos; SKOS concept scheme.</owl:versionInfo>
        <owl:versionInfo xml:lang="en">0.3: Imports modified List ontology</owl:versionInfo>
        <vann:preferredNamespacePrefix>cons</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceURI rdf:resource="https://cdm.ovh/rst/cons/cons"/>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.org/dc/elements/1.1/creator -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/creator"/>
    


    <!-- http://purl.org/dc/elements/1.1/date -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/date"/>
    


    <!-- http://purl.org/dc/terms/description -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/description"/>
    


    <!-- http://purl.org/dc/terms/license -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>
    


    <!-- http://purl.org/dc/terms/title -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/title"/>
    


    <!-- https://vocab.org/vann/preferredNamespacePrefix -->

    <owl:AnnotationProperty rdf:about="https://vocab.org/vann/preferredNamespacePrefix"/>
    


    <!-- https://vocab.org/vann/preferredNamespaceURI -->

    <owl:AnnotationProperty rdf:about="https://vocab.org/vann/preferredNamespaceURI"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.w3.org/2001/XMLSchema#decimal -->

    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#decimal"/>
    


    <!-- http://www.w3.org/2001/XMLSchema#integer -->

    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#integer"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://cdm.ovh/rsm/list2/list2#hasNext -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/list2/list2#hasNext"/>
    


    <!-- https://cdm.ovh/rst/cons/cons#coupledTo -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rst/cons/cons#coupledTo">
        <rdfs:subPropertyOf rdf:resource="https://cdm.ovh/rst/cons/cons#facesExtremity"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:comment xml:lang="en">Symmetric property &quot;coupled to&quot; relates two extremities of two distinct Rolling stock items (hence the &quot;to&quot; in the label). The property is expressed irrespectively of the type of coupling (mechanical, virtual) or coupler (UIC, Scharfenberg...).</rdfs:comment>
        <rdfs:label>coupled to</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rst/cons/cons#extremity_1 -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rst/cons/cons#extremity_1">
        <rdfs:subPropertyOf rdf:resource="https://cdm.ovh/rst/cons/cons#hasExtremity"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <owl:propertyDisjointWith rdf:resource="https://cdm.ovh/rst/cons/cons#extremity_2"/>
        <rdfs:comment xml:lang="en">&quot;extremity 1&quot; (actual designation may vary) of a Rolling stock. This extremity is inherent to the rolling stock, this unrelated to the direction of travel.</rdfs:comment>
        <rdfs:label xml:lang="en">extremity_1</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rst/cons/cons#extremity_2 -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rst/cons/cons#extremity_2">
        <rdfs:subPropertyOf rdf:resource="https://cdm.ovh/rst/cons/cons#hasExtremity"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdfs:comment xml:lang="en">&quot;extremity 2&quot; of a piece of Rolling stock. Designation may vary.</rdfs:comment>
        <rdfs:label xml:lang="en">extremity_2</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rst/cons/cons#facesExtremity -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rst/cons/cons#facesExtremity">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rst/cons/cons#Extremity"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rst/cons/cons#Extremity"/>
        <rdfs:comment xml:lang="en">object is the extremity of another Rolling stock that the subject extremity faces.</rdfs:comment>
        <rdfs:label xml:lang="en">faces extremity</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rst/cons/cons#frontExtremity -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rst/cons/cons#frontExtremity">
        <rdfs:subPropertyOf rdf:resource="https://cdm.ovh/rst/cons/cons#hasExtremity"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rst/cons/cons#ListedRollingStock"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rst/cons/cons#Extremity"/>
        <rdfs:comment xml:lang="en">The extremity first encountered when considering the formation in the listed order. This property orients the vehicle in the formation that itself is oriented. Note: when considering a passing-by train, the first encountered vehicles and vehicle extremities depend on running direction that is NOT considered here at all. The preeent ontology only describes rolling stock.</rdfs:comment>
        <rdfs:label xml:lang="en">front extremity</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rst/cons/cons#hasExtremity -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rst/cons/cons#hasExtremity">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rst/cons/cons#RollingStock"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rst/cons/cons#Extremity"/>
        <rdfs:label xml:lang="en">has extremity</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rst/cons/cons#hasHeadRollingStock -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rst/cons/cons#hasHeadRollingStock">
        <rdfs:subPropertyOf rdf:resource="https://cdm.ovh/rst/cons/cons#includesRollingStock"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rst/cons/cons#Formation"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rst/cons/cons#ListedRollingStock"/>
        <rdfs:comment xml:lang="en">Each formation has exactly one &quot;First&quot; rolling stock. This notion of &quot;first&quot; is only related to the rolling stock, not however to the direction of travel which may vary (general case of multiple units or reversible trains) or not (case of hauled freight trains). Please also not that the direction of movement is yet another notion (think of shunting).</rdfs:comment>
        <rdfs:label xml:lang="en">has head rolling stock</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rst/cons/cons#hasNextRollingStock -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rst/cons/cons#hasNextRollingStock">
        <rdfs:subPropertyOf rdf:resource="https://cdm.ovh/rsm/list2/list2#hasNext"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rst/cons/cons#ListedRollingStock"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://cdm.ovh/rsm/list2/list2#EmptyList"/>
                    <rdf:Description rdf:about="https://cdm.ovh/rst/cons/cons#ListedRollingStock"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Indicates which Rolling stock comes next in a Consist. The &apos; next rolling stock&apos; can be a vehicle, a formation, or an instance of EmptyList (for which the list:emptyList individual is the recommended form).</rdfs:comment>
        <rdfs:label xml:lang="en">has next rolling stock</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rst/cons/cons#hasSide -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rst/cons/cons#hasSide">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rst/cons/cons#RollingStock"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rst/cons/cons#RollingStockSide"/>
        <rdfs:label xml:lang="en">has side</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rst/cons/cons#includesRollingStock -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rst/cons/cons#includesRollingStock">
        <owl:inverseOf rdf:resource="https://cdm.ovh/rst/cons/cons#partOfFormation"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rst/cons/cons#Formation"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rst/cons/cons#RollingStock"/>
        <rdfs:comment xml:lang="en">This property describes the composition of a Formation. A Formation may incude any rolling stock (i.e. vehicles or formations). Irreflexive property: a formation cannot include itself; in other words, it may only have proper parts. This property and its inverse are ancillary properties, to be derived from the nested, listed rolling stock. Consistency of consist representations is the responsibility of the user.</rdfs:comment>
        <rdfs:label xml:lang="en">includes Rolling stock</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rst/cons/cons#isExtremityOf -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rst/cons/cons#isExtremityOf">
        <rdfs:subPropertyOf>
            <rdf:Description>
                <owl:inverseOf rdf:resource="https://cdm.ovh/rst/cons/cons#hasExtremity"/>
            </rdf:Description>
        </rdfs:subPropertyOf>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:label xml:lang="en">is extremity of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rst/cons/cons#isSide -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rst/cons/cons#isSide">
        <rdfs:domain rdf:resource="https://cdm.ovh/rst/cons/cons#RollingStockSide"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:comment xml:lang="en">property objects can be found under the scheme https://cdm.ovh/rsm/schemes/side. Not a functional property, as e.g. &quot;left&quot; can be combined with either &quot;exterior&quot; or &quot; interior&quot; (orientation + polarity)</rdfs:comment>
        <rdfs:label xml:lang="en">is side</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rst/cons/cons#isSideOf -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rst/cons/cons#isSideOf">
        <rdfs:subPropertyOf>
            <rdf:Description>
                <owl:inverseOf rdf:resource="https://cdm.ovh/rst/cons/cons#hasSide"/>
            </rdf:Description>
        </rdfs:subPropertyOf>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:label>is side of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rst/cons/cons#partOfFormation -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rst/cons/cons#partOfFormation">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:comment xml:lang="en">Inverse of &quot;includes Rolling Stock&quot;. A functional property: a rolling stock can only be part of one formation. Irreflexive property: A formation cannot be part of itself.</rdfs:comment>
        <rdfs:label xml:lang="en">part of formation</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rst/cons/cons#rstLocation -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rst/cons/cons#rstLocation">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rst/cons/cons#LocatedRollingStockElement"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/localisation/loca#BaseLocation"/>
        <rdfs:comment xml:lang="en">The rolling stock location can be represented as a linear location (e.g. position along a track) or a spot location (e.g. location of the front axle on the track centerline) according to needs or conventions. These may give rise to several subclasses with definite semantics. In less typical cases (e.g. workshop floorplan), an area location can be used.</rdfs:comment>
        <rdfs:label xml:lang="en">rolling stock location</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://cdm.ovh/rst/cons/cons#hasMetricLength -->

    <owl:DatatypeProperty rdf:about="https://cdm.ovh/rst/cons/cons#hasMetricLength">
        <rdfs:domain rdf:resource="https://cdm.ovh/rst/cons/cons#RollingStock"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:label xml:lang="en">has metric length</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://cdm.ovh/rst/cons/cons#lengthOverBuffers -->

    <owl:DatatypeProperty rdf:about="https://cdm.ovh/rst/cons/cons#lengthOverBuffers">
        <rdfs:subPropertyOf rdf:resource="https://cdm.ovh/rst/cons/cons#hasMetricLength"/>
        <rdfs:label xml:lang="en">length over buffers</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://cdm.ovh/rst/cons/cons#lengthOverCouplers -->

    <owl:DatatypeProperty rdf:about="https://cdm.ovh/rst/cons/cons#lengthOverCouplers">
        <rdfs:subPropertyOf rdf:resource="https://cdm.ovh/rst/cons/cons#hasMetricLength"/>
        <rdfs:label xml:lang="en">length over couplers</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://cdm.ovh/rst/cons/cons#positionInFormation -->

    <owl:DatatypeProperty rdf:about="https://cdm.ovh/rst/cons/cons#positionInFormation">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rst/cons/cons#RollingStock"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">Starting with 1. Ancillary property, the value of which shall be derived from the nested rolling stock list</rdfs:comment>
        <rdfs:label xml:lang="en">position in formation</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#DesignedArtifact -->

    <owl:Class rdf:about="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#DesignedArtifact"/>
    


    <!-- http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#PhysicalArtifact -->

    <owl:Class rdf:about="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#PhysicalArtifact"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#Concept -->

    <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#Concept">
        <rdfs:label xml:lang="en">Concept</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/list2/list2#EmptyList -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/list2/list2#EmptyList">
        <owl:disjointWith rdf:resource="https://cdm.ovh/rst/cons/cons#ListedRollingStock"/>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/list2/list2#OWLList -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/list2/list2#OWLList"/>
    


    <!-- https://cdm.ovh/rsm/localisation/loca#BaseLocation -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/localisation/loca#BaseLocation"/>
    


    <!-- https://cdm.ovh/rst/cons/cons#Extremity -->

    <owl:Class rdf:about="https://cdm.ovh/rst/cons/cons#Extremity">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rst/cons/cons#LocatedRollingStockElement"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://cdm.ovh/rst/cons/cons#hasExtremity"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">denotes the extremity of a rolling stock. The extremity designation is either set at design and manufacturing time (e.g. extremity1, extremity 2 in the case of a wagon), or rests on other conventions (e.g. extremities of a variable-consist trainset).</rdfs:comment>
        <rdfs:label xml:lang="en">Extremity</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rst/cons/cons#Formation -->

    <owl:Class rdf:about="https://cdm.ovh/rst/cons/cons#Formation">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rst/cons/cons#RollingStock"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/rst/cons/cons#includesRollingStock"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/rst/cons/cons#Vehicle"/>
        <rdfs:comment xml:lang="en">A sequence of vehicles (or other formations) that are coupled in some way (mechanically or virtually).</rdfs:comment>
        <rdfs:label xml:lang="en">Formation</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rst/cons/cons#ListedRollingStock -->

    <owl:Class rdf:about="https://cdm.ovh/rst/cons/cons#ListedRollingStock">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/list2/list2#OWLList"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rst/cons/cons#RollingStock"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/rst/cons/cons#hasNextRollingStock"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Rolling stock that may have a predecessor or successor in a formation.</rdfs:comment>
        <rdfs:label xml:lang="en">Listed rolling stock</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rst/cons/cons#LocatedRollingStockElement -->

    <owl:Class rdf:about="https://cdm.ovh/rst/cons/cons#LocatedRollingStockElement">
        <rdfs:label xml:lang="en">Located rolling stock element</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rst/cons/cons#RollingStock -->

    <owl:Class rdf:about="https://cdm.ovh/rst/cons/cons#RollingStock">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#PhysicalArtifact"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rst/cons/cons#LocatedRollingStockElement"/>
        <rdfs:comment xml:lang="en">Base type for rolling stock. No direct instances are expected.</rdfs:comment>
        <rdfs:label xml:lang="en">Rolling stock</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rst/cons/cons#RollingStockSide -->

    <owl:Class rdf:about="https://cdm.ovh/rst/cons/cons#RollingStockSide">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/rst/cons/cons#isSide"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">The side of a particular rolling stock, as in &quot;the left side of locomotive BB15046&quot;.</rdfs:comment>
        <rdfs:label xml:lang="en">Rolling stock side</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rst/cons/cons#Vehicle -->

    <owl:Class rdf:about="https://cdm.ovh/rst/cons/cons#Vehicle">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#DesignedArtifact"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rst/cons/cons#RollingStock"/>
        <rdfs:comment xml:lang="en">Common definition in Directives 2016/797, 2016/798:
 a railway vehicle suitable for circulation on wheels on railway lines, with or without traction; a vehicle is composed of one or more structural and functional subsystems

ERA vocabulary 3.0.0: A specific vehicle or wagon able to operate over railway lines.</rdfs:comment>
        <rdfs:comment xml:lang="en">Considered to be the atomic part of a piece of rolling stock, although disassembly may be carried out in special circumstances. Example: a TALGO or TGV trailer does not rest on two axles resp. bogies, but has a distinct carbody and it considered a vehicle (called &quot;trailer&quot;).  Further example: an articulated wagon (3-axle, e.g. carrying cars) is generally considered a single vehicle although it has two distinct chassis. So the distinction vehicle / formation is conventional; being &quot;atomic&quot; in operations is a necessary condition, but not a sufficient one to be called vehicle.</rdfs:comment>
        <rdfs:label xml:lang="en">Vehicle</rdfs:label>
    </owl:Class>
</rdf:RDF>




              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>length over couplers</lexicalForm>
                <datatype>http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral</datatype>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://cdm.ovh/rst/cons/cons#partOfFormation</value>
          <functional/>
          <irreflexive/>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rst/cons/cons#partOfFormation</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>part of formation</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rst/cons/cons#partOfFormation</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Inverse of "includes Rolling Stock". A functional property: a rolling stock can only be part of one formation. Irreflexive property: A formation cannot be part of itself.</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://cdm.ovh/rst/cons/cons#positionInFormation</value>
          <functional/>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rst/cons/cons#positionInFormation</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>position in formation</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rst/cons/cons#positionInFormation</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Starting with 1. Ancillary property, the value of which shall be derived from the nested rolling stock list</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://cdm.ovh/rst/cons/cons#rstLocation</value>
          <inverseFunctional/>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rst/cons/cons#rstLocation</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>rolling stock location</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rst/cons/cons#rstLocation</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>The rolling stock location can be represented as a linear location (e.g. position along a track) or a spot location (e.g. location of the front axle on the track centerline) according to needs or conventions. These may give rise to several subclasses with definite semantics. In less typical cases (e.g. workshop floorplan), an area location can be used.</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>

          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rst/cons/cons#RollingStockSide</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>Rolling stock side</lexicalForm>

        <iri>
          <value>https://cdm.ovh/rst/cons/cons#Extremity</value>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rst/cons/cons#Extremity</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>Extremity</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rst/cons/cons#Extremity</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>denotes the extremity of a rolling stock. The extremity designation is either set at design and manufacturing time (e.g. extremity1, extremity 2 in the case of a wagon), or rests on other conventions (e.g. extremities of a variable-consist trainset).</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://cdm.ovh/rst/cons/cons#Formation</value>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rst/cons/cons#Formation</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>Formation</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rst/cons/cons#Formation</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>A sequence of vehicles (or other formations) that are coupled in some way (mechanically or virtually).</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>

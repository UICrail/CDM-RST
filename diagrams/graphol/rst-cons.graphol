        <iri>
          <value>https://cdm.ovh/rst/cons/cons#frontExtremity</value>
          <functional/>
          <inverseFunctional/>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rst/cons/cons#frontExtremity</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>front extremity</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rst/cons/cons#frontExtremity</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>The extremity first encountered when considering the formation in the listed order. This property orients the vehicle in the formation that itself is oriented. Note: when considering a passing-by train, the first encountered vehicles and vehicle extremities depend on running direction that is NOT considered here at all. The preeent ontology only describes rolling stock.</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>

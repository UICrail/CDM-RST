        <iri>
          <value>https://cdm.ovh/rst/cons/cons#Formation</value>
        </iri>
        <iri>
          <value>https://cdm.ovh/rst/cons/cons#Vehicle</value>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rst/cons/cons#Vehicle</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Common definition in Directives 2016/797, 2016/798:
 a railway vehicle suitable for circulation on wheels on railway lines, with or without traction; a vehicle is composed of one or more structural and functional subsystems

ERA vocabulary 3.0.0: A specific vehicle or wagon able to operate over railway lines.</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://cdm.ovh/rst/typo/typo#Coach</value>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rst/typo/typo#Coach</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>TSI LOCPAS 2020:
a vehicle without traction in a fixed or variable formation capable of carrying passengers (by extension, requirements specified to apply to coaches in this TSI are deemed to apply also to restaurant cars, sleeping cars, couchettes cars, etc.)

Note: was "passenger carriage" in earlier versions.</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://cdm.ovh/rst/typo/typo#FreightCarryingRollingStock</value>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rst/typo/typo#FreightCarryingRollingStock</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Feature of Rolling stock: ability to carry freight, by design.</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://cdm.ovh/rst/typo/typo#Locomotive</value>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rst/typo/typo#Locomotive</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Powered vehicle having a driving desk and can be used standalone (e.g. for shunting or ferrying movements), but is normally used for hauling other vehicles or formations.</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rst/typo/typo#Locomotive</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>Locomotive</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://cdm.ovh/rst/typo/typo#MotorCar</value>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rst/typo/typo#MotorCar</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Powered vehicle that cannot be used standalone, as can be found in trainset (EMUs or DMUs).
May or may not carry passengers.</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://cdm.ovh/rst/typo/typo#MotoredRollingStock</value>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rst/typo/typo#MotoredRollingStock</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Feature of rolling stock that is able by design to exert tractive effort on wheels or (rarely) cogwheels.</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://cdm.ovh/rst/typo/typo#OnTrackMachine</value>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rst/typo/typo#OnTrackMachine</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>a motored railway vehicle used for infrastructure maintenance</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://cdm.ovh/rst/typo/typo#PassengerCarryingRollingStock</value>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rst/typo/typo#PassengerCarryingRollingStock</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Feature of Rolling stock: ability to carry freight, by design.</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://cdm.ovh/rst/typo/typo#RailCar</value>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rst/typo/typo#RailCar</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Wikipedia (12/3/2024): self-propelled railway vehicle designed to transport passengers.
Equiv. to FR: Autorail, DE: Schienenbus (narrower meaning: two axles only).
Note however the numerous variants and ambiguities.</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://cdm.ovh/rst/typo/typo#Rake</value>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rst/typo/typo#Rake</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Any non-powered formation. Examples:
wagon rake;
(fixed consist) set of TGV trailers;
(fixed or variable consist) rake of coaches.</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://cdm.ovh/rst/typo/typo#RoadRailVehicle</value>
        </iri>
        <iri>
          <value>https://cdm.ovh/rst/typo/typo#RoadVehicleRake</value>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rst/typo/typo#RoadVehicleRake</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>From TSI WAG 2023, "unit", 3rd entry:
separate rail bogies connected to compatible road vehicle(s), the combination of which forms a rake of a rail compatible system.</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://cdm.ovh/rst/typo/typo#RollingStockFeature</value>
        </iri>
        <iri>
          <value>https://cdm.ovh/rst/typo/typo#SlaveLocomotive</value>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rst/typo/typo#SlaveLocomotive</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Powered vehicle without driving desk, with energy possibly fed from master locomotive ( = subclass "slug").
Also called "truck" in France, e.g. TC61000.
Do not confuse with master/slave configuration of two normal locomotives ("multiple working" in the UK).</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://cdm.ovh/rst/typo/typo#Trailer</value>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rst/typo/typo#Trailer</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>non-traction, passenger-carrying vehicle that is part of a trainset or of a fixed-consist rake, such as TGV trailer or ICE3 trailer or Talgo trailer.</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://cdm.ovh/rst/typo/typo#Trainset</value>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rst/typo/typo#Trainset</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>TSI LOC&amp;PAS, 2020: a fixed formation that can operate as a train; it is by definition not intended to be reconfigured, except within a workshop environment. It is composed of only motored or of motored and non-motored vehicles.</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://cdm.ovh/rst/typo/typo#Van</value>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rst/typo/typo#Van</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>TSI LOCPAS 2020: a vehicle without traction capable of carrying payload other than passengers, e.g. luggage or mail, intended to be integrated into a fixed or variable formation which is intended to transport passengers.</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://cdm.ovh/rst/typo/typo#Wagon</value>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rst/typo/typo#Wagon</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>A non-powered vehicle designed for carrying freight.</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rst/typo/typo#Wagon</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>Wagon</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://creativecommons.org/licenses/by-sa/4.0/</value>
        </iri>
        <iri>
          <value>ttps://interoperable-europe.ec.europa.eu/sites/default/files/custom-page/attachment/2020-03/EUPL-1.2%20EN.txt</value>
        </iri>
        <iri>
          <value>urn:x-graphol:origin</value>
        </iri>
      </iris>

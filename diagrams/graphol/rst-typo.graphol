      <iris>
        <iri>
          <value>http://cdm.ovh/rsm/rolling_stock/rolling_stock_typology#hasFixedConsist</value>
          <functional/>
          <annotations>
            <annotation>
              <subject>http://cdm.ovh/rsm/rolling_stock/rolling_stock_typology#hasFixedConsist</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Train formation, the consist of which cannot be changed while in operations as it would require interventions in a workshop.</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>http://cdm.ovh/rsm/rolling_tock/typology</value>
          <annotations>
            <annotation>
              <subject>http://cdm.ovh/rsm/rolling_tock/typology</subject>
              <property>http://purl.org/dc/terms/title</property>
              <object>
                <lexicalForm>Railway rolling stock typology</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
            <annotation>
              <subject>http://cdm.ovh/rsm/rolling_tock/typology</subject>
              <property>http://purl.org/dc/terms/description</property>
              <object>
                <lexicalForm>Defines:
* terms such as locomotive, wagon, trailer...
* features such as motored, passenger-carrying, freight-carrying...
* relations with rolling stock composition (vehicle, formation) that is the subject of another ontology.</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
            <annotation>
              <subject>http://cdm.ovh/rsm/rolling_tock/typology</subject>

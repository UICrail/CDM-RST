            <annotation>
              <subject>http://cdm.ovh/rst/typo/typo</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>This ontology was created in the context of the collaboration with the ERJU System Pillar works. The consequence is the preference given to a class hierachy for rolling stock types that is closer to anticipated downstream works (SysML modelling), compared to enumerated types that is another solution often encountered.</lexicalForm>
                <datatype/>
                <language>en</language>
